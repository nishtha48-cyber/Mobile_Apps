<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F8F9FA"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SnapGrid Gallery"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="40dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="30dp"
            android:gravity="center">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="#2196F3"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Capture New Memory"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#666666"
                android:layout_marginBottom="20dp"/>
            <TextView
                android:id="@+id/tvFolderPath"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Folder Chosen" />

            <Button android:id="@+id/btnPickFolder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Choose Storage Folder" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCapture"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Open Camera"
                android:textSize="16sp"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_camera"
                android:backgroundTint="#2196F3"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OR"
        android:layout_margin="30dp"
        android:textColor="#999999"
        android:textStyle="bold"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGallery"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="View Saved Photos"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        app:strokeColor="#2196F3"
        android:textColor="#2196F3"
        app:icon="@android:drawable/ic_menu_gallery"/>

</LinearLayout>










